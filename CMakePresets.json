{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "linux-release-package",
      "displayName": "Linux release packages",
      "description": "Ninja generator, default compiler, RelWithDebInfo for most subprojects",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "amd-llvm_BUILD_TYPE": "Release",
        "therock-host-blas_BUILD_TYPE": "Release",
        "therock-SuiteSparse_BUILD_TYPE": "Release",
        "THEROCK_SPLIT_DEBUG_INFO": "ON",
        "THEROCK_MINIMAL_DEBUG_INFO": "ON",
        "THEROCK_QUIET_INSTALL": "OFF",
        "THEROCK_FLAG_STAMP_LIBRARY_GIT_VERSIONS": "ON"
      }
    },
    {
      "name": "linux-release-asan",
      "displayName": "Linux release asan build",
      "description": "Ninja generator, default compiler, RelWithDebInfo and ASAN for most runtime subprojects",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "amd-llvm_BUILD_TYPE": "Release",
        "therock-host-blas_BUILD_TYPE": "Release",
        "therock-SuiteSparse_BUILD_TYPE": "Release",
        "THEROCK_SANITIZER": "ASAN",
        "amd-llvm_SANITIZER": "OFF",
        "amd-comgr_SANITIZER": "ASAN",
        "hipcc_SANITIZER": "OFF",
        "hipify_SANITIZER": "OFF",
        "aqlprofile_SANITIZER": "OFF",
        "rocprof-trace-decoder_SANITIZER": "OFF",
        "roctracer_SANITIZER": "OFF",
        "CMAKE_CXX_FLAGS_RELWITHDEBINFO": "-O2 -g1",
        "CMAKE_C_FLAGS_RELWITHDEBINFO": "-O2 -g1",
        "CMAKE_CXX_FLAGS": "-g1",
        "CMAKE_C_FLAGS": "-g1",
        "THEROCK_FLAG_STAMP_LIBRARY_GIT_VERSIONS": "ON"
      }
    },
    {
      "name": "linux-release-host-asan",
      "displayName": "Linux release host-only asan build",
      "description": "Ninja generator, default compiler, RelWithDebInfo with host-side ASAN only (no device-side instrumentation)",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "amd-llvm_BUILD_TYPE": "Release",
        "therock-host-blas_BUILD_TYPE": "Release",
        "therock-SuiteSparse_BUILD_TYPE": "Release",
        "THEROCK_SANITIZER": "HOST_ASAN",
        "amd-llvm_SANITIZER": "OFF",
        "amd-comgr_SANITIZER": "HOST_ASAN",
        "hipcc_SANITIZER": "OFF",
        "hipify_SANITIZER": "OFF",
        "aqlprofile_SANITIZER": "OFF",
        "rocprof-trace-decoder_SANITIZER": "OFF",
        "roctracer_SANITIZER": "OFF",
        "CMAKE_CXX_FLAGS_RELWITHDEBINFO": "-O2 -g1",
        "CMAKE_C_FLAGS_RELWITHDEBINFO": "-O2 -g1",
        "CMAKE_CXX_FLAGS": "-g1",
        "CMAKE_C_FLAGS": "-g1",
        "THEROCK_FLAG_STAMP_LIBRARY_GIT_VERSIONS": "ON"
      }
    },
    {
      "name": "linux-release-tsan",
      "displayName": "Linux release tsan build",
      "description": "Ninja generator, default compiler, RelWithDebInfo and TSAN for most runtime subprojects",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "amd-llvm_BUILD_TYPE": "Release",
        "therock-host-blas_BUILD_TYPE": "Release",
        "therock-SuiteSparse_BUILD_TYPE": "Release",
        "THEROCK_SANITIZER": "TSAN",
        "amd-llvm_SANITIZER": "OFF",
        "amd-comgr_SANITIZER": "OFF",
        "hipcc_SANITIZER": "OFF",
        "hipify_SANITIZER": "OFF",
        "aqlprofile_SANITIZER": "OFF",
        "rocprof-trace-decoder_SANITIZER": "OFF",
        "rocprofiler-sdk_SANITIZER": "OFF",
        "roctracer_SANITIZER": "OFF",
        "CMAKE_CXX_FLAGS_RELWITHDEBINFO": "-O2 -g1",
        "CMAKE_C_FLAGS_RELWITHDEBINFO": "-O2 -g1",
        "CMAKE_CXX_FLAGS": "-g1",
        "CMAKE_C_FLAGS": "-g1",
        "THEROCK_FLAG_STAMP_LIBRARY_GIT_VERSIONS": "ON"
      }
    },
    {
      "name": "windows-base",
      "displayName": "Windows base preset",
      "description": "Ninja generator, MSVC (cl.exe), x64 architecture",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "architecture": {
        "value": "host=x64",
        "strategy": "external"
      },
      "toolset": {
        "value": "host=x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl.exe",
        "CMAKE_CXX_COMPILER": "cl.exe",
        "CMAKE_LINKER": "link.exe"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-release",
      "displayName": "Windows release builds preset",
      "description": "Ninja generator, MSVC (cl.exe), x64 architecture, Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "THEROCK_FLAG_STAMP_LIBRARY_GIT_VERSIONS": "ON"
      },
      "inherits": [
        "windows-base"
      ]
    },
    {
      "name": "linux-fastbuild-spike",
      "displayName": "FASTBuild smoke test (minimal tree)",
      "description": "FASTBuild generator (requires CMake 4.2+), feature groups off; validates alternative backend wiring",
      "generator": "FASTBuild",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "THEROCK_ENABLE_ALL": "OFF",
        "THEROCK_ENABLE_CORE": "OFF",
        "THEROCK_ENABLE_COMM_LIBS": "OFF",
        "THEROCK_ENABLE_DEBUG_TOOLS": "OFF",
        "THEROCK_ENABLE_MATH_LIBS": "OFF",
        "THEROCK_ENABLE_ML_LIBS": "OFF",
        "THEROCK_ENABLE_PROFILER": "OFF",
        "THEROCK_ENABLE_DC_TOOLS": "OFF",
        "THEROCK_ENABLE_MEDIA_LIBS": "OFF",
        "THEROCK_ENABLE_HOST_MATH": "OFF",
        "THEROCK_BUNDLE_SYSDEPS": "OFF",
        "BUILD_TESTING": "OFF",
        "THEROCK_QUIET_INSTALL": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-ninja-spike",
      "displayName": "Ninja smoke test (minimal tree, matches linux-fastbuild-spike)",
      "description": "Same cache flags as linux-fastbuild-spike but Ninja; for side-by-side container checks",
      "inherits": [
        "linux-fastbuild-spike"
      ],
      "generator": "Ninja"
    },
    {
      "name": "linux-fastbuild-leaf",
      "displayName": "FASTBuild leaf compile (fmt)",
      "description": "Minimal tree plus therock-fmt; first real C++ compile via FASTBuild",
      "inherits": [
        "linux-fastbuild-spike"
      ],
      "cacheVariables": {
        "THEROCK_ENABLE_FMT": "ON"
      }
    },
    {
      "name": "linux-ninja-leaf",
      "displayName": "Ninja leaf compile (fmt)",
      "description": "Same scope as linux-fastbuild-leaf but Ninja; quick compile test in Docker",
      "inherits": [
        "linux-fastbuild-leaf"
      ],
      "generator": "Ninja"
    },
    {
      "name": "linux-fastbuild-medium",
      "displayName": "FASTBuild medium compile (fftw3)",
      "description": "Leaf preset plus FFTW3 (double/single); many host C translation units for distributed-build demos",
      "inherits": [
        "linux-fastbuild-leaf"
      ],
      "cacheVariables": {
        "THEROCK_ENABLE_FFTW3": "ON"
      }
    }
  ]
}
